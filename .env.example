# Supabase project (e.g. Fotofetch) — Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Optional: canonical URL for copied share links (defaults to current origin)
# VITE_PUBLIC_APP_URL=https://your-production-domain.com

# Optional: Merv CLG Snapshot API base (enables live homepage scan in GOST). Snapshot must allow CORS from this app’s origin.
# VITE_CLG_SNAPSHOT_URL=https://snapshot.mervmarketing.com
