# Supabase project (e.g. Fotofetch) — Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Optional: canonical URL for copied share links (defaults to current origin)
# VITE_PUBLIC_APP_URL=https://your-production-domain.com

# Production (Vercel): server-only — preferred for Live scan (engine in api/lib/mervSnapshotEngine, same rubric as clg-snapshot).
# Get a key at https://console.anthropic.com — ensure billing is active.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional fallback: proxy to an external Snapshot app instead of using ANTHROPIC_API_KEY on GOST.
# CLG_SNAPSHOT_URL=https://snapshot.mervmarketing.com

# Local dev: run `vercel dev` so /api/clg-snapshot exists, with ANTHROPIC_API_KEY in .env.local (Vercel loads it).
# Optional: direct browser → external Snapshot (needs CORS on that host):
# VITE_CLG_SNAPSHOT_URL=https://snapshot.mervmarketing.com
